# PostgreSQL (source of truth)
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# or
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/dbname

# Elasticsearch (search layer — queried before Postgres)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_COMPANY=company_dataset
# Optional for Elastic Cloud
# ELASTICSEARCH_API_KEY=your_api_key

# Scrapingdog (when ES miss or Postgres row insufficient)
SCRAPE_API_KEY=your_key
# Legacy: SCRAPINGDOG_API_KEY
